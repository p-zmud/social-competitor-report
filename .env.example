# social-competitor-report — environment variables (all optional)
#
# You can set these here OR enter them in the dashboard's Settings panel
# (stored locally in data/settings.json). Settings-panel values take precedence.
#
# Copy to .env:  cp .env.example .env

# --- OpenRouter — the LLM that writes per-brand content summaries ---
# Get a key: https://openrouter.ai/settings/keys   (format: sk-or-v1-...)
OPENROUTER_API_KEY=

# --- Apify — scrapes Instagram / TikTok / Facebook ---
# Get a token: https://console.apify.com/account/integrations   (format: apify_api_...)
# Cost: each actor run is billed; a full weekly report (4 brands x 3 platforms)
# is roughly $0.4-0.6.
APIFY_TOKEN=

# --- Optional: default LLM model id (any OpenRouter model) ---
# Overridden by the Settings panel. Default: deepseek/deepseek-v4-flash
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
